{
  "name": "backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && copyfiles -u 1 \"src/docs/*.yaml\" dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agendajs/mongo-backend": "^4.0.1",
    "agenda": "^6.2.4",
    "bcryptjs": "^2.4.3",
