{
  "name": "react-express-template",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "install:all": "pnpm install",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:mobile": "pnpm --filter mobile start",
    "dev": "pnpm --parallel --filter backend --filter frontend dev",
    "build:frontend": "pnpm --filter shared build && pnpm --filter frontend build",
    "build:backend": "pnpm --filter shared build && pnpm --filter backend build",
    "build:all": "pnpm --filter './apps/*' build",
    "start:backend": "pnpm --filter backend start"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
